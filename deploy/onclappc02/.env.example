# Copy to `.env` and fill in. The compose file reads this automatically.

# ---------------------------------------------------------------------------
# Public hostnames (must have Cloudflare DNS records pointing at 140.226.4.71,
# DNS-only / grey cloud, per the monode infrastructure constraints).
# ---------------------------------------------------------------------------
API_HOST=nf-telemetry.cancerdatasci.org
FRONTEND_HOST=cmgd.cancerdatasci.org

# ---------------------------------------------------------------------------
# Postgres connection.
#
# Points at the shared pg_ducklake_18 cluster
# (monode/infrastructure/compose/pg_ducklake_stack) which exposes
# port 5433 on the host. host.docker.internal is wired up by
# `extra_hosts: host-gateway` in docker-compose.yml.
#
# Before first run, create the role and database in the cluster:
#
#   docker exec -it pg_ducklake_18 psql -U postgres -d postgres <<'SQL'
#   CREATE ROLE nf_telemetry WITH LOGIN PASSWORD '<some-password>';
#   CREATE DATABASE nf_telemetry OWNER nf_telemetry;
#   SQL
#
# Do NOT `CREATE EXTENSION pg_duckdb` in this DB — the app is plain
# Postgres and pg_duckdb's planner hooks would only get in the way.
# ---------------------------------------------------------------------------
SQLALCHEMY_URI=postgresql+asyncpg://nf_telemetry:CHANGEME@host.docker.internal:5433/nf_telemetry

# ---------------------------------------------------------------------------
# CORS — defaults to https://${FRONTEND_HOST}. Override if you serve the
# frontend from a different origin (e.g. during cutover testing).
# ---------------------------------------------------------------------------
# CORS_ORIGINS=https://cmgd.cancerdatasci.org,https://curatedmetagenomicdata.web.app
