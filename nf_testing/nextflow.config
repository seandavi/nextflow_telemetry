/*
 * Nextflow configuration for the metagenomics stub test pipeline.
 */

manifest {
    name        = 'nf_testing'
    description = 'Weblog contract test pipeline for nextflow_telemetry'
    version     = '0.1.0'
}

// Weblog reporter — URL overridden at runtime via -with-weblog
// or set here for local dev convenience.
// weblog.url = 'http://localhost:8000/telemetry'

// Default resource limits (overridden per profile)
process {
    cpus   = 1
    memory = '512 MB'
    time   = '10 m'
}

profiles {

    // Local executor, no containers — for integration tests and CI
    test {
        process.executor = 'local'
        dag.enabled      = false
        report.enabled   = false
        timeline.enabled = false
        trace.enabled    = false
    }

    // Standard local run with trace/report enabled
    local {
        process.executor = 'local'
        dag.file         = 'pipeline_dag.html'
        report.file      = 'pipeline_report.html'
        timeline.file    = 'pipeline_timeline.html'
        trace.file       = 'pipeline_trace.txt'
    }

    // Slurm HPC — stub configuration; real partitions/queues set in client config
    slurm {
        process.executor       = 'slurm'
        process.queue          = 'normal'
        process.clusterOptions = '--account=myproject'
        executor {
            queueSize    = 200
            pollInterval = '30 sec'
        }
    }

    // Cloud (Google Life Sciences / Batch) — stub
    cloud {
        process.executor = 'google-batch'
        google.region    = 'us-central1'
    }
}
