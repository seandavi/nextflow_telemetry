#!/bin/bash
#SBATCH --mem={{ mem }}
#SBATCH --cpus-per-task={{ cpus }}
#SBATCH --time={{ time }}
#SBATCH --qos={{ qos }}
#SBATCH --partition={{ partition }}
#SBATCH --job-name={{ run_name }}
#SBATCH --output={{ log_dir }}/slurm-%j.out

export GOOGLE_APPLICATION_CREDENTIALS={{ google_credentials }}

module load singularity
module load git
module load nextflow

WORKDIR=/scratch/alpine/$USER/nf_worker/$SLURM_JOB_ID
mkdir -p $WORKDIR
mkdir -p {{ log_dir }}
cd $WORKDIR

mkdir -p tempdir
export TMPDIR=$WORKDIR/tempdir
export NXF_TEMP=$WORKDIR/tempdir
export NXF_SINGULARITY_CACHEDIR={{ singularity_cache }}
export NXF_HOME={{ nxf_home }}

# Override config: enable SLURM executor for per-sample tasks, write output to log_dir
cat << 'NFOVERRIDE' > nextflow_alpine_override.config
process.executor = 'slurm'
process.clusterOptions = '--partition {{ partition }} --qos={{ qos }} --output={{ log_dir }}/nf-%j.out'
process.queueSize = 200
process.time = '24h'
NFOVERRIDE

cat << 'METATSV' > metadata.tsv
{{ metadata_tsv_content }}
METATSV

# Put the nf-client executable on PATH for this job so `nf-client run-wrapper`
# resolves. With `uv tool install`, nf-client lands in ~/.local/bin — set
# submission.defaults.client_env_setup to e.g. "export PATH=$HOME/.local/bin:$PATH".
# Without it the run_wrapper call below is not found and the run fails before
# nextflow starts.
{{ client_env_setup | default('') }}

# Wrap nextflow in run_wrapper: it emits run-lifecycle telemetry
# (wrapper_started / heartbeat / wrapper_exited) and uploads .nextflow.log to
# the server on exit, so driver-level deaths are visible server-side instead of
# only in a log file on this node. Telemetry failures are swallowed; the wrapper
# propagates nextflow's exit code.
nf-client run-wrapper \
  --run-name {{ run_name }} \
  --telemetry-url {{ server_url }} \
  -- \
  nextflow run {{ workflow_repository }} \
    -name {{ run_name }} \
    -revision {{ workflow_revision }} \
    -profile {{ profile }} \
    -c nextflow_alpine_override.config \
    --metadata_tsv metadata.tsv \
    --run_name {{ run_name }} \
    -with-weblog {{ weblog_url }}

NF_EXIT=$?
echo "Nextflow exited with code $NF_EXIT"
cp .nextflow.log {{ log_dir }}/nextflow-${SLURM_JOB_ID}.log 2>/dev/null || true
rm -rf $WORKDIR

# Notify server so it can sweep incomplete jobs even if Nextflow crashed.
curl -sS --max-time 30 --retry 3 \
  -X POST "{{ server_url }}/admin/close-run?run_name={{ run_name }}" \
  -o /dev/null || echo "WARN: close-run notification failed"

exit $NF_EXIT
